#!/usr/bin/env bash

# 1. Pipe options into rofi in dmenu mode
choice=$(echo -e "poweroff\nsuspend\nlogout\nreboot\nhibernate" | rofi -dmenu -i -p "Action:")

# 2. Run the command based on what you clicked
case "$choice" in
    poweroff) systemctl poweroff ;;
    reboot) systemctl reboot ;;
    suspend) systemctl suspend ;;
    hibernate) systemctl hibernate ;;
    logout) loginctl terminate-user "$USER" ;; 
esac
